  <div class="ctl grow"><label for="schoolSearch">Search schools</label><input id="schoolSearch" type="text" placeholder="Type a school name…" autocomplete="off"></div>
</div></div>
<main class="wrap">
  <section><div class="eyebrow"><span class="k">01</span><h2>How schools rank</h2><span class="note" id="rankNote"></span></div>
    <div class="tabs" id="tabs"><button data-m="avg_living" class="on">Living satisfaction</button><button data-m="avg_phys">Physical condition</button><button data-m="avg_rent">Rent + utilities</button><button data-m="pct_oncampus">% on campus</button></div>
    <div class="benchline" id="benchline"><span class="sw"></span><span id="benchText"></span></div>
    <div id="rankChart"></div></section>
  <section id="compareSec"><div class="eyebrow"><span class="k">02</span><h2>Compare schools head to head</h2><span class="note">Pick 2 to 6 schools to line them up</span></div>
  <div class="cmp-controls">
