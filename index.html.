    <button id="cmpClear" class="cmp-clear">Clear all</button>
    <span class="cmp-hint" id="cmpHint">Add schools to build a side by side comparison.</span>
  </div>
  <div id="cmpChips" class="cmp-chips"></div>
  <div id="cmpBody" class="cmp-body"></div>
</section>
<section><div class="eyebrow"><span class="k">03</span><h2>Satisfaction breakdown</h2><span class="note">Click any school for its deep dive</span></div><div class="grid" id="distGrid"></div></section>
  <section><div class="eyebrow"><span class="k">04</span><h2>What moves satisfaction</h2><span class="note">Avg living rating by group · all schools</span></div><div class="cutg" id="cutGrid"></div></section>
  <section><div class="eyebrow"><span class="k">05</span><h2>Does paying more buy happiness?</h2><span class="note">Each dot is a school · click to open it</span></div><div class="panel" id="scatterPanel"></div></section>
  <section><div class="eyebrow"><span class="k">06</span><h2>Industry trend over time</h2><span class="note">Avg satisfaction by survey year</span></div><div class="panel" id="trendPanel"></div></section>
</main>
<footer><div class="wrap"><span id="footMeta"></span><span>© 2026 Rieth Jones Advisors · Built on the cleaned RJA Housing Database</span></div></footer>

<div class="overlay" id="overlay"><div class="modal">
  <div class="modal-head"><div><h2 id="ddTitle"></h2><div class="sub" id="ddSub"></div></div><button class="x" id="ddClose">×</button></div>
  <div class="modal-body">
    <div class="kpis" id="ddKpis"></div>
    <div class="takeaway" id="ddTake"></div>
    <div class="dd-grid">
      <div class="dd-block"><h4>Satisfaction by building condition</h4><div id="ddPhys"></div></div>
