$('#schoolPick').addEventListener('change',e=>{if(e.target.value)openDeep(e.target.value);});

function filtered(){
  const st=$('#stateFilter').value,mn=+$('#minN').value,q=$('#schoolSearch').value.trim().toLowerCase();
  return DATA.schools.filter(s=>(!st||s.state===st)&&s.n_total>=mn&&(!q||s.name.toLowerCase().includes(q)));
}

function renderRank(){
  const m=METRICS[curM];let rows=filtered().filter(s=>s[curM]!=null);
  rows.sort((a,b)=>m.higher?b[curM]-a[curM]:a[curM]-b[curM]);
  const maxv=m.max||Math.max(...rows.map(s=>s[curM]),1)*1.05;
  $('#rankNote').textContent=`${rows.length} schools · ${m.higher?'best to worst':'lowest to highest'} · click a school for its deep dive`;
  if(m.bench!=null){$('#benchText').textContent=`Industry average ${m.fmt(m.bench)}${m.unit}`;$('#benchline').style.display='flex';}
  else $('#benchline').style.display='none';
  if(!rows.length){$('#rankChart').innerHTML='<div class="empty">No schools match these filters.</div>';return;}
  $('#rankChart').innerHTML=rows.map(s=>{
    const v=s[curM],w=Math.max(2,v/maxv*100);let flag='';
    if(m.bench!=null){const ab=v>=m.bench,good=m.higher?ab:!ab;flag=`<span class="flag ${good?'up':'dn'}">${ab?'▲':'▼'}${m.fmt(Math.abs(v-m.bench))}</span>`;}
    const bp=m.bench!=null?Math.min(100,m.bench/maxv*100):null;
    return `<div class="bar-row" data-n="${s.name}"><div class="bar-name" title="${s.name}">${s.name}<span class="st"> · ${s.state}</span></div>
     <div class="bar-track"><div class="bar-fill" style="width:${w}%"></div>${bp!=null?`<div style="position:absolute;top:-2px;bottom:-2px;left:${bp}%;border-left:2px dashed var(--bench)"></div>`:''}</div>
     <div class="bar-val">${m.fmt(v)}${flag}</div></div>`;}).join('');
  $$('.bar-row').forEach(r=>{r.addEventListener('click',()=>openDeep(r.dataset.n));
    r.addEventListener('mousemove',e=>{const s=byName[r.dataset.n];showTip(`<b>${s.name}</b><br>${fN(s.n_total)} responses<br>Living ${f(s.avg_living,2)} · Phys ${f(s.avg_phys,2)}<br>Rent ${fM(s.avg_rent)} · ${f(s.pct_oncampus,0)}% on campus<br><i>click for deep dive</i>`,e.clientX,e.clientY);});
    r.addEventListener('mouseleave',hideTip);});
}

function renderDist(){
  const L=DATA.meta.living_labels;
  const rows=filtered().filter(s=>s.living_dist.reduce((a,b)=>a+b,0)>0).sort((a,b)=>b.avg_living-a.avg_living);
  if(!rows.length){$('#distGrid').innerHTML='<div class="empty">No schools match these filters.</div>';return;}
  $('#distGrid').innerHTML=rows.map(s=>{
    const tot=s.living_dist.reduce((a,b)=>a+b,0);
    const segs=s.living_dist.map((c,i)=>{const p=tot?c/tot*100:0;return p>0?`<div class="seg s${i}" style="width:${p}%"></div>`:'';}).join('');
    const good=tot?((s.living_dist[3]+s.living_dist[4])/tot*100):0;
    return `<div class="card" data-n="${s.name}"><h3>${s.name}</h3>
     <div class="csub">${fN(tot)} rated · ${good.toFixed(0)}% Good or better · avg ${f(s.avg_living,2)}/5</div>
     <div class="stack">${segs}</div>
     <div class="legend"><span><i class="s4"></i>Very Good</span><span><i class="s3"></i>Good</span><span><i class="s2"></i>Acceptable</span><span><i class="s1"></i>Needs Impr.</span><span><i class="s0"></i>Not Accept.</span></div></div>`;
  }).join('');
  $$('#distGrid .card').forEach(c=>c.addEventListener('click',()=>openDeep(c.dataset.n)));
}

function renderCuts(){
  const w=$('#cutGrid');w.innerHTML='';
  Object.entries(DATA.cuts).forEach(([t,rows])=>{
    if(!rows||!rows.length)return;
    const body=rows.map(r=>{const wd=r.avg/5*100;const c=r.group.replace(/^I /,'').replace(/ campus$/,'');
      return `<div class="crow" title="${r.group}: ${f(r.avg,2)} · ${fN(r.n)} resp"><div class="cn">${c}</div><div class="ct"><div class="cf" style="width:${wd}%"></div></div><div class="cv">${f(r.avg,2)}</div></div>`;}).join('');
    const d=document.createElement('div');d.className='cut';d.innerHTML=`<h4>${t}<span>1–5 scale</span></h4>${body}`;w.appendChild(d);
  });
}

function renderScatter(){
  const pts=DATA.scatter.filter(p=>p.rent&&p.living);const W=1000,H=420,pad={l:60,r:30,t:20,b:50};
  const xs=pts.map(p=>p.rent),ys=pts.map(p=>p.living);
  const xmin=Math.min(...xs)*.9,xmax=Math.max(...xs)*1.05,ymin=Math.min(...ys)-.2,ymax=Math.max(...ys)+.2;
  const X=v=>pad.l+(v-xmin)/(xmax-xmin)*(W-pad.l-pad.r),Y=v=>H-pad.b-(v-ymin)/(ymax-ymin)*(H-pad.t-pad.b);
  let g='';
  for(let i=0;i<=4;i++){const yv=ymin+(ymax-ymin)*i/4,y=Y(yv);g+=`<line class="gridline" x1="${pad.l}" y1="${y}" x2="${W-pad.r}" y2="${y}"/><text class="axis" x="${pad.l-8}" y="${y+3}" text-anchor="end">${yv.toFixed(1)}</text>`;}
  for(let i=0;i<=4;i++){const xv=xmin+(xmax-xmin)*i/4,x=X(xv);g+=`<line class="gridline" x1="${x}" y1="${pad.t}" x2="${x}" y2="${H-pad.b}"/><text class="axis" x="${x}" y="${H-pad.b+16}" text-anchor="middle">$${Math.round(xv)}</text>`;}
  pts.forEach(p=>{const r=Math.min(4+Math.sqrt(p.n)/8,16);g+=`<circle class="dot" cx="${X(p.rent)}" cy="${Y(p.living)}" r="${r}" data-n="${p.name}" data-r="${p.rent}" data-l="${p.living}" data-c="${p.n}"/>`;});
  g+=`<text class="axis" x="${W/2}" y="${H-6}" text-anchor="middle" style="font-size:11px">Average rent + utilities ($/mo)</text><text class="axis" transform="rotate(-90 16 ${H/2})" x="16" y="${H/2}" text-anchor="middle" style="font-size:11px">Avg living satisfaction (1–5)</text>`;
  $('#scatterPanel').innerHTML=`<svg viewBox="0 0 ${W} ${H}">${g}</svg>`;
  $$('#scatterPanel .dot').forEach(d=>{d.addEventListener('click',()=>openDeep(d.dataset.n));
    d.addEventListener('mousemove',e=>showTip(`<b>${d.dataset.n}</b><br>Rent ${fM(+d.dataset.r)}/mo · ${f(+d.dataset.l,2)}/5<br>${fN(+d.dataset.c)} responses<br><i>click for deep dive</i>`,e.clientX,e.clientY));
    d.addEventListener('mouseleave',hideTip);});
}

function renderTrend(){
  const pts=DATA.trend;const W=1000,H=300,pad={l:50,r:30,t:20,b:40},ymin=3.5,ymax=4.2;
  const X=i=>pad.l+i/(pts.length-1)*(W-pad.l-pad.r),Y=v=>H-pad.b-(v-ymin)/(ymax-ymin)*(H-pad.t-pad.b);
  let g='';for(let i=0;i<=3;i++){const yv=ymin+(ymax-ymin)*i/3,y=Y(yv);g+=`<line class="gridline" x1="${pad.l}" y1="${y}" x2="${W-pad.r}" y2="${y}"/><text class="axis" x="${pad.l-8}" y="${y+3}" text-anchor="end">${yv.toFixed(1)}</text>`;}
  g+=`<polygon class="tarea" points="${pts.map((p,i)=>`${X(i)},${Y(p.avg)}`).join(' ')} ${X(pts.length-1)},${H-pad.b} ${X(0)},${H-pad.b}"/>`;
  g+=`<polyline class="tline" points="${pts.map((p,i)=>`${X(i)},${Y(p.avg)}`).join(' ')}"/>`;
  pts.forEach((p,i)=>{g+=`<circle class="tdot" cx="${X(i)}" cy="${Y(p.avg)}" r="4" data-y="${p.year}" data-a="${p.avg}" data-n="${p.n}"/><text class="axis" x="${X(i)}" y="${H-pad.b+16}" text-anchor="middle">${p.year}</text><text class="dotlabel" x="${X(i)}" y="${Y(p.avg)-9}" text-anchor="middle">${p.avg.toFixed(2)}</text>`;});
  $('#trendPanel').innerHTML=`<svg viewBox="0 0 ${W} ${H}">${g}</svg>`;
  $$('#trendPanel .tdot').forEach(d=>{d.addEventListener('mousemove',e=>showTip(`<b>${d.dataset.y}</b><br>Avg ${f(+d.dataset.a,2)}/5<br>${fN(+d.dataset.n)} responses`,e.clientX,e.clientY));d.addEventListener('mouseleave',hideTip);});
}

// ---- DEEP DIVE ----
function miniBars(rows,color,maxv){
  if(!rows||!rows.length)return '<div style="font-size:11.5px;color:var(--ink-2)">Not enough data for this school.</div>';
  return rows.map(r=>{const w=r.avg/(maxv||5)*100;
    return `<div class="minibar" title="${r.g}: ${f(r.avg,2)} · ${fN(r.n)} resp"><div class="mn">${r.g}</div><div class="mt"><div class="mf" style="width:${w}%;background:${color}"></div></div><div class="mv">${f(r.avg,2)}</div></div>`;}).join('');
}
function sparkline(trend){
  if(!trend||trend.length<2)return '<div style="font-size:11.5px;color:var(--ink-2)">Single year of data.</div>';
  const W=380,H=110,pad={l:28,r:12,t:14,b:22},ymin=Math.min(...trend.map(t=>t.avg))-.2,ymax=Math.max(...trend.map(t=>t.avg))+.2;
  const X=i=>pad.l+i/(trend.length-1)*(W-pad.l-pad.r),Y=v=>H-pad.b-(v-ymin)/(ymax-ymin)*(H-pad.t-pad.b);
  let g=`<polyline class="tline" points="${trend.map((p,i)=>`${X(i)},${Y(p.avg)}`).join(' ')}"/>`;
  trend.forEach((p,i)=>{g+=`<circle class="tdot" cx="${X(i)}" cy="${Y(p.avg)}" r="3.5"/><text class="axis" x="${X(i)}" y="${H-6}" text-anchor="middle">${p.year}</text><text class="dotlabel" x="${X(i)}" y="${Y(p.avg)-7}" text-anchor="middle">${p.avg.toFixed(2)}</text>`;});
  return `<svg viewBox="0 0 ${W} ${H}">${g}</svg>`;
}
function openDeep(name){
  const s=byName[name],d=DATA.school_detail[name];if(!s)return;
  $('#ddTitle').textContent=s.name;
  $('#ddSub').textContent=`${s.state} · ${fN(s.n_total)} responses · ${s.years.join(', ')}`;
  const vs=v=>v==null?null:(v-DATA.meta.avg_living);
  $('#ddKpis').innerHTML=[
    [f(s.avg_living,2),'Living (1–5)',true],[f(s.avg_phys,2),'Phys condition',false],
    [fM(s.avg_rent),'Rent + util/mo',false],[s.pct_oncampus!=null?f(s.pct_oncampus,0)+'%':'—','On campus',false],
    [d.good_pct!=null?d.good_pct+'%':'—','Good or better',false],[fN(s.n_rated),'Rated responses',false]
  ].map(([n,l,hi])=>`<div class="kpi"><div class="n ${hi?'':'muted'}">${n}</div><div class="l">${l}</div></div>`).join('');
  // takeaway
  const diff=s.avg_living-DATA.meta.avg_living;
  const dir=diff>=0?'above':'below';
  let phys='';
  if(d.phys_link&&d.phys_link.length>=2){const lo=d.phys_link[0].avg,hi=d.phys_link[d.phys_link.length-1].avg;phys=` Students who rate the building's condition highest report satisfaction of ${f(hi,2)}, versus ${f(lo,2)} for the lowest, the strongest pattern in the data.`;}
  $('#ddTake').innerHTML=`<b>${s.name}</b> sits ${f(Math.abs(diff),2)} points ${dir} the ${f(DATA.meta.avg_living,2)} industry average for living satisfaction.${phys}`;
  $('#ddPhys').innerHTML=miniBars(d.phys_link,'var(--teal)',5);
  $('#ddOnOff').innerHTML=miniBars(d.on_off,'var(--rja)',5);
  $('#ddClass').innerHTML=miniBars(d.by_class,'var(--rja)',5);
  $('#ddRent').innerHTML=miniBars(d.rent_bands,'var(--teal)',5);
  $('#ddTrend').innerHTML=sparkline(d.trend);
  $('#overlay').classList.add('open');document.body.style.overflow='hidden';
}
function closeDeep(){$('#overlay').classList.remove('open');document.body.style.overflow='';$('#schoolPick').value='';}
$('#ddClose').addEventListener('click',closeDeep);
$('#overlay').addEventListener('click',e=>{if(e.target.id==='overlay')closeDeep();});
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeDeep();});

function renderAll(){renderRank();renderDist();}
$$('#tabs button').forEach(b=>b.addEventListener('click',()=>{$$('#tabs button').forEach(x=>x.classList.remove('on'));b.classList.add('on');curM=b.dataset.m;renderRank();}));
['#stateFilter','#minN'].forEach(s=>$(s).addEventListener('change',renderAll));
$('#schoolSearch').addEventListener('input',renderAll);

// ---- COMPARE MODE ----
const CMP_COLORS=['#2D9CDB','#27AE60','#F2994A','#9B51E0','#EB5757','#00BFA6'];
let cmpSel=[];
const cmpSelEl=document.querySelector('#cmpAdd');
[...DATA.schools].sort((a,b)=>a.name.localeCompare(b.name)).forEach(s=>{
  const o=document.createElement('option');o.value=s.name;o.textContent=s.name+' ('+s.state+')';cmpSelEl.appendChild(o);
});
cmpSelEl.addEventListener('change',e=>{const v=e.target.value;if(v&&!cmpSel.includes(v)&&cmpSel.length<6){cmpSel.push(v);renderCompare();}e.target.value='';});
document.querySelector('#cmpClear').addEventListener('click',()=>{cmpSel=[];renderCompare();});

function cmpColor(i){return CMP_COLORS[i%CMP_COLORS.length];}
function renderCompare(){
  const chips=document.querySelector('#cmpChips'),body=document.querySelector('#cmpBody'),hint=document.querySelector('#cmpHint');
  chips.innerHTML=cmpSel.map((n,i)=>`<div class="chip"><span class="dot" style="background:${cmpColor(i)}"></span>${n}<button data-n="${n}" aria-label="remove">×</button></div>`).join('');
  chips.querySelectorAll('button').forEach(b=>b.addEventListener('click',()=>{cmpSel=cmpSel.filter(x=>x!==b.dataset.n);renderCompare();}));
  hint.textContent = cmpSel.length? `${cmpSel.length} of 6 selected` : 'Add schools to build a side by side comparison.';
  if(cmpSel.length<2){body.innerHTML='<div class="cmp-empty">Pick at least two schools to compare them side by side.</div>';return;}
  const rows=cmpSel.map(n=>byName[n]);
  const metrics=[
    {k:'avg_living',label:'Living satisfaction',unit:'/5',fmt:v=>f(v,2),max:5,higher:true},
    {k:'avg_phys',label:'Physical condition',unit:'/5',fmt:v=>f(v,2),max:5,higher:true},
    {k:'avg_rent',label:'Rent + utilities',unit:'/mo',fmt:fM,max:Math.max(...rows.map(r=>r.avg_rent||0))*1.1,higher:false},
    {k:'pct_oncampus',label:'On campus',unit:'%',fmt:v=>f(v,0)+'%',max:100,higher:true}
  ];
  let html='';
  metrics.forEach(m=>{
    const vals=rows.map(r=>r[m.k]).filter(v=>v!=null);
    if(!vals.length)return;
    const best=m.higher?Math.max(...vals):Math.min(...vals);
    html+=`<div class="cmp-metric"><h4>${m.label}<span>${m.higher?'higher is better':'lower is better'}</span></h4>`;
    rows.forEach((r,i)=>{const v=r[m.k];if(v==null){html+=`<div class="cmp-bar"><div class="nm">${r.name}</div><div class="tk"></div><div class="vl">—</div></div>`;return;}
      const w=Math.max(2,v/m.max*100);const isBest=v===best;
      html+=`<div class="cmp-bar"><div class="nm" title="${r.name}">${r.name}</div><div class="tk"><div class="fl" style="width:${w}%;background:${cmpColor(i)}"></div></div><div class="vl" style="color:${isBest?'var(--pos)':'inherit'}">${m.fmt(v)}</div></div>`;});
    html+='</div>';
  });
  // comparison table
  const tblRows=[
    ['Responses',r=>fN(r.n_total),false],
    ['Rated responses',r=>fN(r.n_rated),false],
    ['Living satisfaction (1-5)',r=>f(r.avg_living,2),'avg_living','hi'],
    ['Physical condition (1-5)',r=>f(r.avg_phys,2),'avg_phys','hi'],
    ['Rent + utilities',r=>fM(r.avg_rent),'avg_rent','lo'],
    ['Avg commute (min)',r=>r.avg_commute!=null?f(r.avg_commute,0):'—',false],
    ['% on campus',r=>r.pct_oncampus!=null?f(r.pct_oncampus,0)+'%':'—',false],
    ['Good or better',r=>{const t=r.living_dist.reduce((a,b)=>a+b,0);return t?Math.round((r.living_dist[3]+r.living_dist[4])/t*100)+'%':'—';},false],
    ['Years',r=>r.years.join(', '),false],
    ['State',r=>r.state,false],
  ];
  let tbl='<table class="cmp-table"><thead><tr><th>Metric</th>'+rows.map((r,i)=>`<th style="border-top:3px solid ${cmpColor(i)}">${r.name}</th>`).join('')+'</tr></thead><tbody>';
  tblRows.forEach(([label,fn,key,dir])=>{
    let bestVal=null;
    if(key){const vs=rows.map(r=>r[key]).filter(v=>v!=null);if(vs.length)bestVal=dir==='lo'?Math.min(...vs):Math.max(...vs);}
    tbl+=`<tr><td>${label}</td>`+rows.map(r=>{
      const disp=fn(r);const hit=key&&r[key]!=null&&r[key]===bestVal;
      return `<td class="${hit?'cmp-best':''}">${disp}</td>`;}).join('')+'</tr>';
  });
  tbl+='</tbody></table>';
  body.innerHTML=html+tbl;
}
renderCompare();

renderAll();renderCuts();renderScatter();renderTrend();
</script></body></html>
