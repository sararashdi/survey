<!DOCTYPE html><html lang="en"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>RJA Student Housing Intelligence</title>
<style>
:root{
  --slate:#343E48; --slate-2:#2E3740; --slate-3:#262E36; --slate-line:#3F4A55;
  --ink:#2B333B; --ink-2:#677078; --line:#E4E7EA; --line-2:#CDD3D8;
  --paper:#FFFFFF; --paper-2:#F6F7F8;
  --rja:#343E48; --rja-dark:#2E3740; --rja-soft:#EAECEE;
  --teal:#56616B; --teal-mid:#7C858E; --blue:#A7AFB6;
  --accent:#343E48; --accent-soft:#E8EAEC;
  --bad:#8A9098; --good:#343E48; --bench:#AEB5BB;

  --c1:#3E7CB1; --c2:#3C9D7E; --c3:#D98A47; --c4:#7B6CA8; --c5:#C25B58; --c6:#D4B25A; --c7:#3FA7A0;
  --pos:#3C9D7E; --neg:#C25B58; --hi:#3E7CB1;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:"Helvetica Neue",Arial,"Segoe UI",sans-serif;color:var(--ink);background:var(--paper-2);
  line-height:1.5;font-variant-numeric:tabular-nums;-webkit-font-smoothing:antialiased}
.wrap{max-width:1180px;margin:0 auto;padding:0 24px}
a{color:var(--rja-dark)}

/* Masthead with RJA wordmark */
header{background:var(--slate);color:#fff}.logo{display:flex;align-items:center;gap:13px}.rja-img{height:42px;width:auto;display:block;padding-right:14px;border-right:1px solid var(--slate-line)}.logo .txt b{font-size:16px;font-weight:600;letter-spacing:.2em;display:block;color:#fff}.logo .txt span{font-size:10px;color:#A7AFB6;letter-spacing:.18em;text-transform:uppercase;margin-top:3px;display:block}
.mast{display:flex;align-items:center;justify-content:space-between;max-width:1180px;margin:0 auto;padding:18px 24px;flex-wrap:wrap;gap:14px}






.mast .tag{font-size:12px;color:#A7AFB6;text-align:right;max-width:360px}
.mast .tag b{color:#fff;font-weight:600}

/* sub-band facts */
.facts-band{background:var(--slate-2);border-top:1px solid var(--slate-line);color:#fff}
.facts{display:flex;gap:0;max-width:1180px;margin:0 auto;flex-wrap:wrap}
.fact{flex:1;min-width:130px;padding:14px 24px;border-right:1px solid var(--slate-line)}
.fact:last-child{border-right:none}
.fact .n{font-size:22px;font-weight:700;color:#FFFFFF}
.fact .l{font-size:10.5px;color:#A7AFB6;text-transform:uppercase;letter-spacing:.05em;margin-top:2px}

/* controls */
.controls{background:var(--paper);border-bottom:1px solid var(--line-2);position:sticky;top:0;z-index:30}
.cinner{display:flex;gap:18px;align-items:flex-end;max-width:1180px;margin:0 auto;padding:13px 24px;flex-wrap:wrap}
.ctl label{display:block;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-2);font-weight:700;margin-bottom:3px}
.ctl select,.ctl input{font:inherit;font-size:13px;padding:8px 11px;border:1px solid var(--line-2);background:var(--paper);color:var(--ink);min-width:200px}
.ctl select:focus,.ctl input:focus{outline:2px solid var(--rja);outline-offset:-1px}
.ctl.grow{flex:1;min-width:220px}
.ctl.grow input{width:100%}

section{padding:34px 0 4px}
.eyebrow{display:flex;align-items:baseline;gap:12px;border-bottom:2px solid var(--slate);padding-bottom:8px;margin-bottom:20px}
.eyebrow .k{font-size:11px;font-weight:800;color:#3E7CB1;letter-spacing:.1em}
.eyebrow h2{font-size:18px;font-weight:700}
.eyebrow .note{font-size:12px;color:var(--ink-2);margin-left:auto;text-align:right}

/* metric tabs */
.tabs{display:flex;border:1px solid var(--line-2);width:fit-content;margin-bottom:16px;flex-wrap:wrap}
.tabs button{font:inherit;font-size:12.5px;font-weight:600;padding:8px 15px;border:none;background:var(--paper);color:var(--ink-2);cursor:pointer;border-right:1px solid var(--line-2)}
.tabs button:last-child{border-right:none}
.tabs button.on{background:var(--rja);color:#fff}

.benchline{display:flex;align-items:center;gap:8px;font-size:11.5px;color:var(--ink-2);margin-bottom:12px}
.benchline .sw{width:18px;border-top:2px dashed var(--bench)}

/* ranked bars */
.bar-row{display:grid;grid-template-columns:228px 1fr 92px;align-items:center;gap:14px;padding:7px 0;border-bottom:1px solid var(--line);cursor:pointer}
.bar-row:hover{background:var(--rja-soft)}
.bar-name{font-size:12.5px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.bar-name .st{color:var(--ink-2);font-size:11px}
.bar-track{position:relative;height:18px;background:var(--paper-2)}
.bar-fill{position:absolute;left:0;top:0;height:100%;background:linear-gradient(90deg,#3E7CB1,#5B97C9);transition:width .5s cubic-bezier(.22,.61,.36,1)}
.bar-val{font-size:12.5px;font-weight:700;text-align:right;display:flex;justify-content:flex-end;align-items:center;gap:5px}
.flag{font-size:10px;padding:1px 5px;border:1px solid var(--line-2)}
.flag.up{color:var(--pos);border-color:#cfe6dd;background:#eef7f3}.flag.dn{color:var(--neg);border-color:#ecd2d1;background:#faefef}

/* grid + cards */
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(310px,1fr));gap:18px}
.card{background:var(--paper);border:1px solid var(--line);padding:17px;cursor:pointer;transition:border-color .15s,box-shadow .15s}
.card:hover{border-color:var(--slate);box-shadow:0 2px 0 var(--slate)}
.card h3{font-size:13.5px;font-weight:700}
.card .csub{font-size:11.5px;color:var(--ink-2);margin:2px 0 13px}
.stack{display:flex;height:16px;border:1px solid var(--line);overflow:hidden}
.seg{height:100%}
.s0{background:#C25B58}.s1{background:#D98A47}.s2{background:#D4B25A}.s3{background:#7FB59E}.s4{background:#3C9D7E}
.legend{display:flex;gap:13px;flex-wrap:wrap;font-size:10.5px;color:var(--ink-2);margin-top:7px}
.legend span{display:flex;align-items:center;gap:5px}.legend i{width:10px;height:10px;display:inline-block}

/* cut cards */
.cutg{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px}
.cut{background:var(--paper);border:1px solid var(--line);padding:15px}
.cut h4{font-size:12.5px;font-weight:700;margin-bottom:11px;display:flex;justify-content:space-between}
.cut h4 span{font-size:10px;color:var(--ink-2);font-weight:400}
.crow{display:grid;grid-template-columns:118px 1fr 34px;align-items:center;gap:8px;margin-bottom:6px}
.crow .cn{font-size:11.5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.crow .ct{height:13px;background:var(--paper-2);position:relative}
.crow .cf{position:absolute;left:0;top:0;height:100%;background:#3FA7A0}
.crow .cv{font-size:11.5px;font-weight:700;text-align:right}

svg{display:block;width:100%;height:auto;font-family:inherit}
.panel{background:var(--paper);border:1px solid var(--line);padding:18px}
.gridline{stroke:var(--line)}
.axis text{fill:var(--ink-2);font-size:10px}
.dot{fill:#7B6CA8;opacity:.8;cursor:pointer}.dot:hover{opacity:1}
.tline{fill:none;stroke:#3E7CB1;stroke-width:2.5}.tdot{fill:#3E7CB1}.tarea{fill:#eaf1f7}
.dotlabel{font-size:9px;fill:var(--ink-2)}

/* deep-dive modal */
.overlay{position:fixed;inset:0;background:rgba(20,18,15,.55);z-index:60;display:none;align-items:flex-start;justify-content:center;padding:40px 16px;overflow:auto}
.overlay.open{display:flex}
.modal{background:var(--paper);max-width:920px;width:100%;border-top:4px solid var(--slate)}
.modal-head{display:flex;justify-content:space-between;align-items:flex-start;padding:20px 24px;border-bottom:1px solid var(--line)}
.modal-head h2{font-size:19px;font-weight:700}
.modal-head .sub{font-size:12px;color:var(--ink-2);margin-top:3px}
.modal-head .x{font-size:24px;line-height:1;background:none;border:none;cursor:pointer;color:var(--ink-2)}
.modal-body{padding:22px 24px 28px}
.kpis{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:1px;background:var(--line);border:1px solid var(--line);margin-bottom:22px}
.kpi{background:var(--paper);padding:13px 15px}
.kpi .n{font-size:19px;font-weight:700;color:#3E7CB1}
.kpi .n.muted{color:var(--slate)}
.kpi .l{font-size:10px;color:var(--ink-2);text-transform:uppercase;letter-spacing:.04em;margin-top:2px}
.dd-grid{display:grid;grid-template-columns:1fr 1fr;gap:22px}
.dd-block h4{font-size:12.5px;font-weight:700;margin-bottom:10px;padding-bottom:5px;border-bottom:1px solid var(--line)}
.takeaway{background:#eef3f8;border-left:3px solid #3E7CB1;padding:12px 14px;font-size:12.5px;margin-bottom:20px}
.takeaway b{color:#3E7CB1}
.minibar{display:grid;grid-template-columns:110px 1fr 32px;align-items:center;gap:7px;margin-bottom:5px}
.minibar .mn{font-size:11px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.minibar .mt{height:12px;background:var(--paper-2);position:relative}
.minibar .mf{position:absolute;left:0;top:0;height:100%}
.minibar .mv{font-size:11px;font-weight:700;text-align:right}


/* Compare schools */
.cmp-controls{display:flex;gap:12px;align-items:center;margin-bottom:14px;flex-wrap:wrap}
.cmp-controls select{font:inherit;font-size:13px;padding:8px 11px;border:1px solid var(--line-2);background:var(--paper);min-width:240px}
.cmp-controls select:focus{outline:2px solid var(--c1);outline-offset:-1px}
.cmp-clear{font:inherit;font-size:12px;padding:7px 13px;border:1px solid var(--line-2);background:var(--paper);cursor:pointer;color:var(--ink-2)}
.cmp-clear:hover{border-color:var(--neg);color:var(--neg)}
.cmp-hint{font-size:12px;color:var(--ink-2)}
.cmp-chips{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:18px}
.chip{display:flex;align-items:center;gap:8px;padding:5px 8px 5px 11px;border:1px solid var(--line-2);font-size:12.5px;background:var(--paper)}
.chip .dot{width:11px;height:11px;border-radius:50%;display:inline-block}
.chip button{border:none;background:none;cursor:pointer;font-size:15px;line-height:1;color:var(--ink-2);padding:0 2px}
.chip button:hover{color:var(--neg)}
.cmp-empty{padding:30px;text-align:center;color:var(--ink-2);border:1px dashed var(--line-2)}
.cmp-metric{margin-bottom:22px}
.cmp-metric h4{font-size:12.5px;font-weight:700;margin-bottom:9px;display:flex;justify-content:space-between}
.cmp-metric h4 span{font-size:10.5px;color:var(--ink-2);font-weight:400}
.cmp-bar{display:grid;grid-template-columns:170px 1fr 70px;align-items:center;gap:12px;margin-bottom:6px}
.cmp-bar .nm{font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.cmp-bar .tk{height:16px;background:var(--paper-2);position:relative}
.cmp-bar .fl{position:absolute;left:0;top:0;height:100%;transition:width .4s}
.cmp-bar .vl{font-size:12px;font-weight:700;text-align:right}
.cmp-table{width:100%;border-collapse:collapse;font-size:12.5px;margin-top:6px;overflow-x:auto;display:block}
.cmp-table th,.cmp-table td{border:1px solid var(--line);padding:8px 10px;text-align:right;white-space:nowrap}
.cmp-table th:first-child,.cmp-table td:first-child{text-align:left;font-weight:600;position:sticky;left:0;background:var(--paper)}
.cmp-table thead th{background:var(--slate);color:#fff;font-weight:600}
.cmp-table tbody tr:nth-child(even){background:var(--paper-2)}
.cmp-best{color:var(--pos);font-weight:700}

footer{padding:30px 0 50px;color:var(--ink-2);font-size:11.5px;border-top:1px solid var(--line);margin-top:28px}
footer .wrap{display:flex;justify-content:space-between;flex-wrap:wrap;gap:10px}
.tooltip{position:fixed;pointer-events:none;background:var(--ink);color:#fff;font-size:11.5px;padding:6px 9px;border-radius:2px;opacity:0;transition:opacity .12s;z-index:80;max-width:230px;line-height:1.35}
.empty{padding:36px;text-align:center;color:var(--ink-2)}
@media(max-width:680px){.bar-row{grid-template-columns:120px 1fr 70px;gap:8px}.dd-grid{grid-template-columns:1fr}.crow{grid-template-columns:84px 1fr 30px}}
</style></head><body>
<header><div class="mast">
  <div class="logo"><img class="rja-img" src="data:image/png;base64," alt="RJA"/><div class="txt"><b>RIETH&nbsp;JONES</b><span>Advisors&nbsp;·&nbsp;Housing Intelligence</span></div></div>
  <div class="tag">Cross-institution survey analysis across <b>19 universities</b>. Pick any school for a full deep dive.</div>
</div></header>
<div class="facts-band"><div class="facts" id="facts"></div></div>
<div class="controls"><div class="cinner">
  <div class="ctl"><label for="schoolPick">Open a school deep dive</label>
    <select id="schoolPick"><option value="">Choose a school…</option></select></div>
